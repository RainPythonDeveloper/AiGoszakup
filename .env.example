# === API OWS v3 ===
GOSZAKUP_API_TOKEN=your_bearer_token_here
GOSZAKUP_API_BASE_URL=https://ows.goszakup.gov.kz

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=goszakup
POSTGRES_USER=goszakup
POSTGRES_PASSWORD=changeme_strong_password

# === LLM (nitec-ai, OpenAI-compatible) ===
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://nitec-ai.kz/api
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=openai/gpt-oss-120b

# === App ===
APP_PORT=8000
LOG_LEVEL=INFO

# === Airflow ===
# AIRFLOW__CORE__FERNET_KEY=
